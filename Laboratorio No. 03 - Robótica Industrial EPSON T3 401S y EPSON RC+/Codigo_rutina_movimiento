Function MoverHuevo(pos_origen As Integer, pos_destino As Integer)
    ' 1. Ir a la casilla donde está el huevo actualmente
    Jump Pallet(1, pos_origen)
    
    ' 2. Activar la herramienta (ventosa o gripper)
    ' Asegúrate de que "Succ" sea el nombre correcto de tu salida I/O
    Off 9
    
    Wait 1 ' Tiempo de espera para asegurar el agarre
    
    ' 3. Saltar a la nueva casilla (destino)
    Jump Pallet(1, pos_destino)
    
    ' 4. Soltar el huevo
    On 9
    
    Wait 1 ' Tiempo de espera para que libere completamente
Fend
